# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key (Claude models) and/or OpenAI API key (GPT models). You need
# the key(s) for whichever provider your selected model(s) use. The default model
# is GPT (OpenAI); the summarizer defaults to Haiku (Anthropic).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Base URL of the Bullseye API (login + all data tools). May also be set in the
# repo-root .env; set here only to override.
BULLSEYE_BASE_URL=

# ── Observability (LangSmith) ─────────────────────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=bullseye-copilot

# ── Agent defaults ────────────────────────────────────────────────────────────
# BULLSEYE_MODEL=sonnet        # sonnet | opus | haiku
# BULLSEYE_EFFORT=low          # minimal | low | medium | high | xhigh | max
# BULLSEYE_MAX_TURNS=25
# BULLSEYE_ENABLE_HITL=0       # 1 = enforced confirm-before-write interrupt (needs frontend resume)

# ── Cost controls ─────────────────────────────────────────────────────────────
# Context editing — clear old tool outputs from context once it grows (cheap, no
# LLM call). Biggest input-cost lever for multi-tool turns.
# BULLSEYE_ENABLE_CONTEXT_EDITING=1
# BULLSEYE_CONTEXT_EDIT_TRIGGER_TOKENS=15000  # clear old tool results past this (keep < summary trigger)
# BULLSEYE_CONTEXT_EDIT_KEEP=3                # keep this many recent tool results
# BULLSEYE_WRITE_FILE_LIMIT=2                 # max full artifact (write_file) rewrites/turn; 0 = no cap; excess steered to Edit

# Conversation-history summarization (bounds per-turn input cost on long chats).
# BULLSEYE_ENABLE_SUMMARIZATION=1
# BULLSEYE_SUMMARY_TRIGGER_TOKENS=20000   # summarize once history crosses this
# BULLSEYE_SUMMARY_KEEP_MESSAGES=20       # keep this many recent messages verbatim
# BULLSEYE_SUMMARY_MODEL=haiku            # cheap model used to write summaries

# ── Server ────────────────────────────────────────────────────────────────────
# HOST=127.0.0.1
# PORT=8000   # matches frontend/vite.config.ts dev proxy

# ── Paths (defaults use the repo's own bundled assets — override only if you move them) ──
# BULLSEYE_MCP_DIR=../bullseye-mcp
# BULLSEYE_PROMPT_PATH=../prompts/bullseye_copilot_system_prompt.md
# BULLSEYE_KNOWLEDGE_DIR=../knowledge/help
# ARTIFACTS_ROOT=../artifacts

# ── Optional tools ────────────────────────────────────────────────────────────
# TAVILY_API_KEY=              # enables the web_search tool
