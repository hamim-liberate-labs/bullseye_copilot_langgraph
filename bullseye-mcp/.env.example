# Required
BULLSEYE_BASE_URL=https://your-bullseye-instance.example.com
BULLSEYE_EMAIL=your@email.com
BULLSEYE_PASSWORD=yourpassword

# Optional
# BULLSEYE_TIMEOUT=30          # HTTP timeout in seconds (default 30)
# BULLSEYE_LOG_LEVEL=INFO      # logging level (default INFO)
# BULLSEYE_TOKEN=              # pre-issued JWT (per-user passthrough; skips password sign-in)
# BULLSEYE_SCHOOL_ID=          # active school id (else defaults to first /schools entry)
# BULLSEYE_WORKDIR=            # set to enable gateway mode (bulk results offload to <workdir>/data/)
# BULLSEYE_OFFLOAD_MIN_BYTES=4096  # gateway mode: payloads smaller than this stay inline (default 4096)
